rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isHardcodedAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "kanthong.03439@gmail.com" || 
         request.auth.token.email == "kanthong.8426@gmail.com");
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          isHardcodedAdmin() ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }
    
    function isApproved() {
      return isAuthenticated() && 
        (
          isAdmin() ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true)
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow get: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow list: if isAdmin();
      allow create: if isAuthenticated() && isOwner(uid);
      allow update: if isAuthenticated() && (
        (isOwner(uid) && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow create: if isAuthenticated() && (isAdmin() || isApproved());
      allow update: if isAuthenticated() && (isAdmin() || isApproved());
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow write: if isAuthenticated() && (isAdmin() || isApproved());
    }

    match /grades/{gradeId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow write: if isAuthenticated() && (isAdmin() || isApproved());
    }

    match /milkBrushing/{recordId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow write: if isAuthenticated() && (isAdmin() || isApproved());
    }

    match /savings/{recordId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow write: if isAuthenticated() && (isAdmin() || isApproved());
    }

    match /health/{recordId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow write: if isAuthenticated() && (isAdmin() || isApproved());
    }

    match /homeVisits/{recordId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow write: if isAuthenticated() && (isAdmin() || isApproved());
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow write: if isAuthenticated() && (isAdmin() || isApproved());
    }
  }
}
